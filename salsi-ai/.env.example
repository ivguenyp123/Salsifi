# Salsi AI — variables du back (à mettre dans ta CI / ton serveur, JAMAIS dans le front)

# ── Projet & modèle GCP ──
GCP_PROJECT=lcl-devops-xxxxx
GCP_LOCATION=europe-west9
VERTEX_MODEL=gemini-2.5-pro

# Auth GCP (Application Default Credentials) : chemin vers la clé du compte de service.
# En CI : écris le contenu de la variable secrète GitLab dans ce fichier au démarrage.
GOOGLE_APPLICATION_CREDENTIALS=/secrets/sa.json

# ── Sécurité ──
# Origines autorisées, séparées par des virgules. En prod, PAS de '*'.
ALLOW_ORIGIN=https://ton-hub.exemple.lcl
# Secret partagé : doit matcher localStorage 'salsi_ai_secret' côté front.
SALSI_SECRET=change-moi
# Filtres de sécurité Vertex : BLOCK_MEDIUM_AND_ABOVE (défaut, sûr) |
# BLOCK_LOW_AND_ABOVE (plus strict mais peut sur-bloquer du jargon DevOps) |
# BLOCK_ONLY_HIGH | BLOCK_NONE.
SAFETY_THRESHOLD=BLOCK_MEDIUM_AND_ABOVE

# ── Anti-abus ──
RATE_MAX=30            # requêtes max par IP par fenêtre
RATE_WINDOW_MS=60000   # taille de la fenêtre (ms)
VERTEX_TIMEOUT_MS=20000

# ── Journal ──
# false = on logge outcome + IP + hash de la question (pas le texte). true = texte tronqué inclus.
LOG_QUESTIONS=false

# Port d'écoute
PORT=8080
